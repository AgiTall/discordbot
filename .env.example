# PostgreSQL. Render supplies this automatically when the database is linked.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/pchevbot

# Discord application credentials from the Developer Portal.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_TOKEN=
OAUTH_REDIRECT_URI=http://localhost:10000/auth/discord/callback

# Generate a long random value for signing dashboard sessions.
SESSION_SECRET_KEY=

FRONTEND_URL=http://localhost:10000
SUPPORT_URL=
PORT=10000
DEBUG=false
RENDER=false
